// tools/csv-to-places-json.mjs
import fs from "fs";

const csv = fs.readFileSync("places.csv", "utf8").trim().split("\n");
const headers = csv[0].split(",").map(s => s.trim());
const rows = csv.slice(1).map(line => {
  const cols = line.split(",").map(s => s.trim());
  const obj = Object.fromEntries(headers.map((h, i) => [h, cols[i] ?? ""]));
  return {
    id: obj.id,
    name: obj.name,
    area: obj.area,
    city: obj.city,
    lat: Number(obj.lat),
    lng: Number(obj.lng),
    category: obj.category,
    subcategory: obj.subcategory,
    indoor: obj.indoor,
    covered: obj.covered,
    ageMin: Number(obj.ageMin || 0),
    ageMax: Number(obj.ageMax || 99),
    energyLevel: obj.energyLevel,
    effortLevel: obj.effortLevel,
    costBand: obj.costBand,
    status: obj.status || "OPEN",
    phone: obj.phone,
    address: obj.address,
    url: obj.url,
    insiderTip: obj.insiderTip,
    notes: obj.notes
  };
});
fs.writeFileSync("src/places.json", JSON.stringify(rows, null, 2));
console.log("Wrote src/places.json", rows.length);


